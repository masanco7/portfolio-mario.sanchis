---
import { getTranslations, type Lang } from '../i18n';

const { lang = 'es' } = Astro.props as { lang?: Lang };
const t = getTranslations(lang);
---
<section id="stack" class="section" style="padding-top: 0;" aria-labelledby="stack-title">
  <div class="container">
    <p class="section-label reveal">{t.stack.sectionLabel}</p>
    <h2 id="stack-title" class="section-title reveal">{t.stack.title}</h2>

    <div class="stack-grid">
      <div class="stack-col reveal">
        <h3 class="stack-col-title">
          <svg class="stack-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 12c0-3 2.5-5 5-5 1.7 0 3 .8 4 2 1-1.5 2.7-3 5-3 3 0 5 2 5 5 0 .3 0 .7-.1 1 1.3.7 2.1 2 2.1 3.5 0 2.2-1.8 4-4 4H6c-2.2 0-4-1.8-4-4 0-1.5.8-2.8 2-3.5z" transform="translate(-1 0)"/>
          </svg>
          {t.stack.salesforce}
        </h3>
        <ul class="stack-list" role="list">
          <li>Apex</li>
          <li>Lightning Web Components</li>
          <li>SOQL</li>
          <li>Flow Builder</li>
          <li>Service Cloud</li>
        </ul>
      </div>

      <div class="stack-col reveal">
        <h3 class="stack-col-title">
          <svg class="stack-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="14" rx="2"/>
            <path d="M3 9h18M7 14h2M11 14h6"/>
          </svg>
          {t.stack.frontend}
        </h3>
        <ul class="stack-list" role="list">
          <li>Angular 21</li>
          <li>TypeScript</li>
          <li>JavaScript</li>
          <li>HTML5 / CSS3</li>
        </ul>
      </div>

      <div class="stack-col reveal">
        <h3 class="stack-col-title">
          <svg class="stack-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <ellipse cx="12" cy="6" rx="8" ry="3"/>
            <path d="M4 6v6c0 1.7 3.6 3 8 3s8-1.3 8-3V6M4 12v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6"/>
          </svg>
          {t.stack.backend}
        </h3>
        <ul class="stack-list" role="list">
          <li>NestJS</li>
          <li>FastAPI</li>
          <li>Node.js</li>
          <li>Python</li>
          <li>Java</li>
          <li>PostgreSQL</li>
          <li>REST APIs</li>
        </ul>
      </div>

      <div class="stack-col reveal">
        <h3 class="stack-col-title">
          <svg class="stack-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9 1.65 1.65 0 0 0 4.27 7.18l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09A1.65 1.65 0 0 0 15 4.6a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
          {t.stack.devops}
        </h3>
        <ul class="stack-list" role="list">
          <li>Git</li>
          <li>GitHub Actions</li>
          <li>Linux / VPS</li>
          <li>nginx</li>
          <li>Postman</li>
          <li>VirtualBox</li>
        </ul>
      </div>
    </div>
  </div>
</section>
