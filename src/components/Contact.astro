---
import { getTranslations, type Lang } from '../i18n';

const { lang = 'es' } = Astro.props as { lang?: Lang };
const t = getTranslations(lang);
---
<section id="contacto" class="section contact" aria-labelledby="contact-title">
  <div class="container">
    <p class="section-label reveal">{t.contact.sectionLabel}</p>
    <h2 id="contact-title" class="contact-title reveal" set:html={t.contact.titleHtml}></h2>
    <p class="contact-lede reveal">{t.contact.lede}</p>

    <ul class="contact-list reveal" role="list">
      <li>
        <a href="mailto:msanchiscolomer@gmail.com">
          <span class="contact-channel">
            <span class="contact-channel-name">{t.contact.channelEmail}</span>
            <span class="contact-channel-value">msanchiscolomer@gmail.com</span>
          </span>
          <svg class="arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 13L13 3M6 3h7v7"/></svg>
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/mario-sanchis-colomer/?skipRedirect=true" target="_blank" rel="noopener">
          <span class="contact-channel">
            <span class="contact-channel-name">{t.contact.channelLinkedIn}</span>
            <span class="contact-channel-value">/in/mario-sanchis-colomer</span>
          </span>
          <svg class="arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 13L13 3M6 3h7v7"/></svg>
        </a>
      </li>
      <li>
        <a href="https://github.com/masanco7" target="_blank" rel="noopener">
          <span class="contact-channel">
            <span class="contact-channel-name">{t.contact.channelGitHub}</span>
            <span class="contact-channel-value">@masanco7</span>
          </span>
          <svg class="arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 13L13 3M6 3h7v7"/></svg>
        </a>
      </li>
      <li>
        <a href="https://www.salesforce.com/trailblazer/mariosanchiscolomer" target="_blank" rel="noopener">
          <span class="contact-channel">
            <span class="contact-channel-name">{t.contact.channelTrailhead}</span>
            <span class="contact-channel-value">/trailblazer/mariosanchiscolomer</span>
          </span>
          <svg class="arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 13L13 3M6 3h7v7"/></svg>
        </a>
      </li>
    </ul>
  </div>
</section>
