---
import { getTranslations, type Lang } from '../i18n';

const { lang = 'es' } = Astro.props as { lang?: Lang };
const t = getTranslations(lang);
---
<section id="sobre-mi" class="section" aria-labelledby="about-title">
  <div class="container">
    <p class="section-label reveal">{t.about.sectionLabel}</p>
    <h2 id="about-title" class="section-title reveal">{t.about.title}</h2>

    <div class="about-grid">
      <div class="about-prose reveal">
        <p set:html={t.about.p1Html}></p>
        <p set:html={t.about.p2Html}></p>
        <p set:html={t.about.p3Html}></p>

        <a class="btn btn-primary" href={t.about.cvFile} download>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v8m0 0l3-3m-3 3L5 7M3 13h10"/></svg>
          {t.about.cvDownload}
        </a>
      </div>

      <aside class="facts">
        <div class="fact reveal">
          <p class="fact-label">{t.about.factEducationLabel}</p>
          <div class="fact-body">
            <div><strong>{t.about.factEducationDegree}</strong></div>
            <div class="meta">{t.about.factEducationMeta}</div>
          </div>
        </div>
        <div class="fact reveal">
          <p class="fact-label">{t.about.factCertsLabel}</p>
          <div class="fact-body">
            {t.about.factCertItems.map((item) => <div>{item}</div>)}
          </div>
        </div>
        <div class="fact reveal">
          <p class="fact-label">{t.about.factLangsLabel}</p>
          <div class="fact-body">
            <div>{t.about.factLangsItem1}</div>
            <div set:html={t.about.factLangsItem2Html}></div>
          </div>
        </div>
        <div class="fact reveal">
          <p class="fact-label">{t.about.factLocationLabel}</p>
          <div class="fact-body">
            <div>{t.about.factLocationCity}</div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
