---
import { getTranslations, type Lang } from '../i18n';

const { lang = 'es' } = Astro.props as { lang?: Lang };
const t = getTranslations(lang);
---
<section id="salesforce" class="sf" aria-labelledby="sf-title">
  <div class="container">
    <header class="sf-header reveal">
      <p class="section-label">{t.salesforce.sectionLabel}</p>
      <h2 id="sf-title" class="sf-title">
        {t.salesforce.title} <span class="sf-title-accent">{t.salesforce.titleAccent}</span>.
      </h2>
      <p class="sf-lede">{t.salesforce.lede}</p>
    </header>

    <article class="trailhead reveal" aria-labelledby="trailhead-title">
      <p class="trailhead-label">{t.salesforce.trailheadLabel}</p>
      <h3 id="trailhead-title" class="trailhead-headline">{t.salesforce.trailheadHeadline}</h3>

      <dl class="trailhead-stats">
        <div class="stat">
          <dt class="stat-label">{t.salesforce.statBadges}</dt>
          <dd class="stat-num">77</dd>
        </div>
        <div class="stat">
          <dt class="stat-label">{t.salesforce.statPoints}</dt>
          <dd class="stat-num">{lang === 'es' ? '66.200' : '66,200'}</dd>
        </div>
        <div class="stat">
          <dt class="stat-label">{t.salesforce.statTrails}</dt>
          <dd class="stat-num">21</dd>
        </div>
        <div class="stat">
          <dt class="stat-label">{t.salesforce.statRank}</dt>
          <dd class="stat-num" style="font-size: 1.25rem; line-height: 1.4; padding-top: 0.4rem;">{t.salesforce.rankValue}</dd>
        </div>
      </dl>

      <div class="trailhead-foot">
        <span class="expeditioner" aria-label={t.salesforce.rankAria}>
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M3 13l5-10 5 10M5.5 9h5"/>
          </svg>
          {t.salesforce.expeditionerRank}
        </span>
        <a class="btn btn-secondary" href="https://www.salesforce.com/trailblazer/mariosanchiscolomer" target="_blank" rel="noopener">
          {t.salesforce.trailheadCta}
          <svg class="arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 13L13 3M6 3h7v7"/></svg>
        </a>
      </div>
    </article>

    <div class="sf-areas reveal">
      <p class="sf-subhead">{t.salesforce.areasSubhead}</p>
      <ul class="tag-list" role="list">
        {t.salesforce.areaTags.map((tag) => <li><span class="tag">{tag}</span></li>)}
      </ul>
    </div>

    <article class="experience reveal" aria-labelledby="exp-role">
      <header class="exp-head">
        <h3 id="exp-role" class="exp-role">
          {t.salesforce.expRole}<span class="at">{t.salesforce.expCompany}</span>
        </h3>
        <span class="exp-dates">{t.salesforce.expDates}</span>
      </header>
      <p class="exp-team">{t.salesforce.expTeam}</p>

      <ul class="exp-bullets">
        {t.salesforce.bulletsHtml.map((html) => <li set:html={html}></li>)}
      </ul>
    </article>

    <div class="sf-foot reveal">
      <p class="sf-goal">
        <span class="sf-goal-label">{t.salesforce.goalLabel}</span>
        <span set:html={t.salesforce.goalHtml}></span>
      </p>
      <a class="btn btn-primary" href={t.salesforce.cvFile} download>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v8m0 0l3-3m-3 3L5 7M3 13h10"/></svg>
        {t.salesforce.cvDownload}
      </a>
    </div>
  </div>
</section>
